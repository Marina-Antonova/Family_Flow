@model CreateEditEventViewModel

@{
    ViewData["Title"] = "Edit Schedule Event";
}

<h2>Edit Schedule Event</h2>

<form asp-action="Edit" method="post" class="mt-4">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="CreatorId" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input asp-for="Id" type="hidden" />

    <div class="mb-3">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="StartTime" class="form-label"></label>
        <input asp-for="StartTime"
               asp-format="{0:yyyy-MM-ddTHH:mm}"
               class="form-control"
               type="datetime-local" />
        <span asp-validation-for="StartTime" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EndTime" class="form-label"></label>
        <input asp-for="EndTime"
               asp-format="{0:yyyy-MM-ddTHH:mm}"
               class="form-control"
               type="datetime-local" />
        <span asp-validation-for="EndTime" class="text-danger"></span>
    </div>

    @if (Model.Adults.All(a => a.Id != Model.CreatorId))
    {
        <div class="mb-3">
            <label asp-for="AccompanyingAdultId" class="form-label-add-edit">Select Adult</label>
            <select asp-for="AccompanyingAdultId" class="form-control" aria-required="true"
                    asp-items="@(new SelectList(Model.Adults, "Id", "Name"))">
                <option value="">Select Adult...</option>
            </select>
            <span asp-validation-for="AccompanyingAdultId" class="text-danger"></span>
        </div>
    }

    <div class="mb-3">
        <label class="form-label-add-edit">Select Participants</label>
        <div id="participants-container">
            @if (Model.SelectedMemberIds.Any())
            {
                @foreach (var selectedMemberId in Model.SelectedMemberIds)
                {
                    <select name="SelectedMemberIds" class="form-control mb-2">
                        <option value="">Select a member...</option>
                        @foreach (var member in Model.Members)
                        {
                            @if (member.Id == selectedMemberId)
                            {
                                <option value="@member.Id" selected="selected">@member.Name</option>
                            }
                            else
                            {
                                <option value="@member.Id">@member.Name</option>
                            }
                        }
                    </select>
                }
            }
            else
            {
                <select name="SelectedMemberIds" class="form-control mb-2">
                    <option value="" selected>Select a member...</option>
                    @foreach (var member in Model.Members.Where(m => m.Id != Model.Id))
                {
                        <option value="@member.Id">@member.Name</option>
                    }
                </select>
            }
        </div>
        <button type="button" id="add-participant-btn" class="btn btn-sm btn-secondary mb-3">+ Add Participant</button>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-area=""
       asp-controller="FamilyMembers"
       asp-action="Details"
       asp-route-id="@Model.CreatorId"
       class="btn btn-secondary">
        Cancel
    </a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (() => {
            const container = document.getElementById('participants-container');
            const addButton = document.getElementById('add-participant-btn');

            if (!container || !addButton) {
                return;
            }

            const createSelect = () => {
                const wrapper = document.createElement('div');
                wrapper.className = 'participant-select-row';

                const select = document.createElement('select');
                select.name = 'SelectedMemberIds';
                select.className = 'form-control mb-2';
                select.innerHTML = `
                    <option value="" selected>Select a member...</option>
                    @foreach (var member in Model.Members.Where(m => m.Id != Model.Id))
                {
                        <option value="@member.Id">@member.Name</option>
                    }
                `;

                wrapper.appendChild(select);
                return wrapper;
            };

            addButton.addEventListener('click', () => {
                container.appendChild(createSelect());
            });
        })();
    </script>
}
