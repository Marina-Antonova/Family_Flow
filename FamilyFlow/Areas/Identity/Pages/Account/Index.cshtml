@page
@model FamilyFlow.Areas.Identity.Pages.Account.IndexModel

@{
    ViewData["Title"] = "My Account";
}

<div class="row justify-content-center mt-4">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom">
                <h3 class="mb-0">My Account</h3>
            </div>

            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Username</dt>
                    <dd class="col-sm-8">@Model.UserName</dd>

                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>

                    <dt class="col-sm-4">Email confirmed</dt>
                    <dd class="col-sm-8">@(Model.IsEmailConfirmed ? "Yes" : "No")</dd>

                    <dt class="col-sm-4">Roles</dt>
                    <dd class="col-sm-8">@Model.RoleSummary</dd>
                </dl>
            </div>

            <div class="card-footer bg-white border-top text-end">
                <a asp-controller="Family"
                   asp-action="MyFamily"
                   asp-area=""
                   class="btn btn-outline-secondary">
                    Back to My Family
                </a>
            </div>
        </div>
    </div>
</div>
