@model FamilyViewModel

@{
    ViewData["Title"] = "My Family";
}

<div class="container mt-4">

    </div>

    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">

            <div class="card shadow-sm border-0">
                <div class="card-body">

                    <h5 class="card-title mb-4 d-flex align-items-center gap-2">
                        🏡 <span>Family Overview</span>
                    </h5>

                    <dl class="row mb-0">
                        <h2 class="mb-1">👨‍👩‍👧‍👦 @Model.Name</h2>
                        <p class="mb-0 opacity-75">Welcome to your family space</p>
                    </dl>

                    <div class="d-flex flex-wrap justify-content-end gap-2 mt-4">

                        <a asp-controller="FamilyMembers"
                           asp-action="All"
                           class="btn btn-primary">
                            👥 Members
                        </a>
                        @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Family"
                        asp-action="Edit"
                        asp-route-id="@Model.Id"
                        class="btn btn-outline-secondary">
                            ✏️ Edit
                        </a>

                        <a asp-controller="Family"
                        asp-action="Delete"
                        asp-route-id="@Model.Id"
                        class="btn btn-outline-danger">
                            🗑 Delete
                        </a>
                    }

                    </div>
                </div>
            </div>

        </div>
    </div>

</div>